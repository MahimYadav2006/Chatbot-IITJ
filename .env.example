# Central LLM switch for the whole project.
# Set to one of: ollama, gemini, bedrock
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1

# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# AWS Bedrock settings
# Uses the Amazon Bedrock bearer token documented as AWS_BEARER_TOKEN_BEDROCK
# For Anthropic Claude via Bedrock API keys, prefer a geo/global inference profile
# ID such as us.anthropic... rather than the raw anthropic... foundation model ID.
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL=qwen.qwen3-32b-v1:0
BEDROCK_FALLBACK_MODEL=qwen.qwen3-32b-v1:0
BEDROCK_REGION=us-east-1

# Optional project-wide runtime settings
VERIFY_RESPONSES=true
EMBEDDING_DEVICE=cpu
SCRAPED_DATA_ROOT=./scraped_data
